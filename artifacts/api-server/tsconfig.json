{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "types": ["node"],
    // Express handlers legitimately mix `return res.json()` (early exits) with
    // fall-through; noImplicitReturns (from the shared base) flags this as TS7030.
    // Scoped off here only — the base config is unchanged for other packages.
    "noImplicitReturns": false
  },
  "include": ["src"],
  "exclude": [
    "src/lib/e2e-simulation.ts",
    "src/lib/stress-simulation.ts",
    "src/load-test.ts"
  ],
  "references": [
    {
      "path": "../../lib/db"
    },
    {
      "path": "../../lib/api-zod"
    }
  ]
}
