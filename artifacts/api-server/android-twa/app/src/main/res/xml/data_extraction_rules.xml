<?xml version="1.0" encoding="utf-8"?>
<!--
    Data-extraction rules (Android 12+). Mirrors android:allowBackup="false":
    nothing of the app's data is included in either cloud backups or device
    transfers. The app holds only a JWT session in WebView storage which is
    cheap to re-acquire by re-login; nothing here is worth backing up.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
